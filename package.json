{
  "name": "bounty-board",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @bounty-board/dapp dev",
    "build": "bun --filter @bounty-board/dapp build",
    "typecheck": "bun --filter @bounty-board/frontier-client typecheck && bun --filter @bounty-board/dapp typecheck",
    "lint": "bun --filter @bounty-board/frontier-client lint && bun --filter @bounty-board/dapp lint",
    "test": "bun --filter @bounty-board/frontier-client test && bun run test:move",
    "test:move": "cd contracts/bounty_board && sui move test",
    "sync:addresses": "bun run scripts/sync-addresses.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.10.4",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.2.4"
  }
}
